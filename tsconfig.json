{
  "compilerOptions": {
    "module": "nodenext",
    "target": "es2022",
    "moduleResolution": "node16",
    "inlineSourceMap": true,
    "allowSyntheticDefaultImports": true,
    "removeComments": true,
    "incremental": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true,
    "outDir": "./",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": ["./**/*"],
  "exclude": ["node_modules"]
}
